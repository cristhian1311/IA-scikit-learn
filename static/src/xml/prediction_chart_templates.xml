<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Template para el widget de gráfico de predicción -->
    <t t-name="sales.prediction_chart_template">
        <div class="o_prediction_chart_container" style="width: 100%; margin: 20px 0;">
            <div id="sale_prediction_chart" style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 15px;">
                <canvas id="prediction_chart"></canvas>
            </div>
        </div>
    </t>
</templates>
